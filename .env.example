APP_NAME=SEC Alert Self-Hosted
APP_HOST=127.0.0.1
APP_ALLOW_CONTAINER_BIND=false
APP_PORT=8000
DATA_DIR=./data
# Leave blank to use the default local SQLite database in DATA_DIR.
DATABASE_URL=
SEC_USER_AGENT=Your Name your-email@example.com
SEC_POLL_INTERVAL_SECONDS=60
SEC_RATE_LIMIT_RPS=2
SEC_LIVE_8K_OVERLAP_ROWS=20
SCHEDULER_ENABLED=false
# Leave blank to auto-generate a local session secret on startup.
SESSION_SECRET=
WATCHLIST_SOFT_CAP=25
WATCHLIST_HARD_CAP=50
SLACK_WEBHOOK_URL=
ALERT_WEBHOOK_URL=
ALERT_WEBHOOK_SECRET=
LOCALHOST_WEBHOOK_TEST_MODE=false
SMTP_HOST=
SMTP_PORT=
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_TO=
# Comma-separated recipients supported, for example: ops@example.com,alerts@example.com
OPENAI_API_KEY=
OPENAI_MODEL=
# Example pinned snapshots: gpt-5-mini-2025-08-07 or gpt-4.1-mini-2025-04-14
# Optional release metadata stamped into the UI/build docs.
APP_BUILD_DATE=
APP_BUILD_SHA=
APP_BUILD_SOURCE=
RELEASE_TARGET_VERSION=
